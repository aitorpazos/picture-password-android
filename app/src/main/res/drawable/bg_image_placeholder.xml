<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Soft gradient background -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:startColor="@color/placeholder_bg_start"
                android:centerColor="@color/placeholder_bg_center"
                android:endColor="@color/placeholder_bg_end"
                android:angle="160" />
        </shape>
    </item>
    <!-- Subtle inner glow border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <stroke
                android:width="1dp"
                android:color="@color/placeholder_border" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    <!-- Dashed inner accent line -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="23dp" />
            <stroke
                android:width="1dp"
                android:color="@color/placeholder_border_dash"
                android:dashWidth="6dp"
                android:dashGap="4dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
