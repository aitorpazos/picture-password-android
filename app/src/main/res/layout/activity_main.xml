<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <!-- App title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Picture Password"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#EEFFFFFF"
        android:letterSpacing="0.02"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BlackBerry-style picture unlock for Android"
        android:textSize="13sp"
        android:textColor="#66FFFFFF"
        android:fontFamily="sans-serif-light"
        android:layout_marginBottom="28dp" />

    <!-- Image preview card -->
    <FrameLayout
        android:id="@+id/previewCard"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginBottom="12dp"
        android:clipToOutline="true"
        android:outlineProvider="background"
        android:background="@drawable/bg_image_placeholder"
        android:elevation="2dp">

        <ImageView
            android:id="@+id/previewImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Password image preview"
            android:visibility="gone" />

        <!-- Placeholder content (shown when no image) -->
        <LinearLayout
            android:id="@+id/placeholderContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_image_placeholder"
                android:contentDescription="No image"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Picture Password configured"
                android:textSize="13sp"
                android:textColor="#44FFFFFF"
                android:fontFamily="sans-serif-light" />
        </LinearLayout>
    </FrameLayout>

    <!-- Status text -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No Picture Password configured"
        android:textSize="14sp"
        android:textColor="#88FFFFFF"
        android:fontFamily="sans-serif-light"
        android:layout_marginBottom="20dp" />

    <!-- Primary action: Setup -->
    <Button
        android:id="@+id/setupButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Setup Picture Password"
        android:textSize="15sp"
        android:textColor="@android:color/white"
        android:textAllCaps="false"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.01"
        android:background="@drawable/bg_button_primary"
        android:stateListAnimator="@null"
        android:layout_marginBottom="10dp" />

    <!-- Secondary action: Test Unlock -->
    <Button
        android:id="@+id/testButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Test Unlock"
        android:textSize="14sp"
        android:textColor="#CCFFFFFF"
        android:textAllCaps="false"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.01"
        android:background="@drawable/bg_button_secondary"
        android:stateListAnimator="@null"
        android:enabled="false"
        android:alpha="0.4"
        android:layout_marginBottom="10dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp" />

    <!-- Lock Screen Service Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lock Screen Service"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#CCFFFFFF"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/serviceStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lock screen service is off"
        android:textSize="13sp"
        android:textColor="#88FFFFFF"
        android:fontFamily="sans-serif-light"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/serviceToggleButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Enable as Lock Screen"
        android:textSize="14sp"
        android:textColor="@android:color/white"
        android:textAllCaps="false"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.01"
        android:background="@drawable/bg_button_primary"
        android:stateListAnimator="@null"
        android:enabled="false"
        android:alpha="0.4"
        android:layout_marginBottom="12dp" />

    <!-- Unlock Mode Settings (visible when service is enabled) -->
    <LinearLayout
        android:id="@+id/settingsSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@drawable/bg_button_secondary"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Unlock Mode"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#CCFFFFFF"
            android:layout_marginBottom="12dp" />

        <RadioGroup
            android:id="@+id/unlockModeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/radioPictureOnly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Picture Password only"
                android:textSize="13sp"
                android:textColor="#BBFFFFFF"
                android:fontFamily="sans-serif-light"
                android:buttonTint="#64B5F6"
                android:paddingStart="8dp"
                android:layout_marginBottom="6dp" />

            <RadioButton
                android:id="@+id/radioBiometricOnly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Biometrics only"
                android:textSize="13sp"
                android:textColor="#BBFFFFFF"
                android:fontFamily="sans-serif-light"
                android:buttonTint="#64B5F6"
                android:paddingStart="8dp"
                android:layout_marginBottom="6dp" />

            <RadioButton
                android:id="@+id/radioBothRequired"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Both required (2FA)"
                android:textSize="13sp"
                android:textColor="#BBFFFFFF"
                android:fontFamily="sans-serif-light"
                android:buttonTint="#64B5F6"
                android:paddingStart="8dp"
                android:layout_marginBottom="6dp" />

            <RadioButton
                android:id="@+id/radioEither"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Either unlocks"
                android:textSize="13sp"
                android:textColor="#BBFFFFFF"
                android:fontFamily="sans-serif-light"
                android:buttonTint="#64B5F6"
                android:paddingStart="8dp" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 For best security, set your system lock to Swipe and use Picture Password as your primary lock."
            android:textSize="11sp"
            android:textColor="#66FFFFFF"
            android:fontFamily="sans-serif-light"
            android:layout_marginTop="12dp" />
    </LinearLayout>

    <!-- Permissions Guide Section -->
    <LinearLayout
        android:id="@+id/permissionsSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@drawable/bg_button_secondary"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ Required Permissions"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#CCFFFFFF"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="The lock screen service needs these permissions to work properly. Tap each item to open the relevant settings."
            android:textSize="12sp"
            android:textColor="#88FFFFFF"
            android:fontFamily="sans-serif-light"
            android:layout_marginBottom="12dp" />

        <!-- Overlay permission -->
        <LinearLayout
            android:id="@+id/permOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_perm_item"
            android:padding="12dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/permOverlayStatus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Display over other apps"
                    android:textSize="13sp"
                    android:textColor="#DDFFFFFF"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Required to show the lock screen. If greyed out, go to App Info → Allow restricted settings first."
                    android:textSize="11sp"
                    android:textColor="#66FFFFFF"
                    android:fontFamily="sans-serif-light" />
            </LinearLayout>
        </LinearLayout>

        <!-- Notification permission -->
        <LinearLayout
            android:id="@+id/permNotification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_perm_item"
            android:padding="12dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/permNotificationStatus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notifications"
                    android:textSize="13sp"
                    android:textColor="#DDFFFFFF"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Required for the foreground service. Android requires a visible notification."
                    android:textSize="11sp"
                    android:textColor="#66FFFFFF"
                    android:fontFamily="sans-serif-light" />
            </LinearLayout>
        </LinearLayout>

        <!-- Battery optimization -->
        <LinearLayout
            android:id="@+id/permBattery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_perm_item"
            android:padding="12dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/permBatteryStatus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unrestricted battery"
                    android:textSize="13sp"
                    android:textColor="#DDFFFFFF"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Prevents Android from killing the service in the background."
                    android:textSize="11sp"
                    android:textColor="#66FFFFFF"
                    android:fontFamily="sans-serif-light" />
            </LinearLayout>
        </LinearLayout>

        <!-- Restricted settings hint -->
        <LinearLayout
            android:id="@+id/permRestricted"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_perm_item"
            android:padding="12dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/permRestrictedStatus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Allow restricted settings"
                    android:textSize="13sp"
                    android:textColor="#DDFFFFFF"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="On Android 13+: Settings → Apps → Picture Password → ⋮ menu → Allow restricted settings. Required before overlay permission can be granted."
                    android:textSize="11sp"
                    android:textColor="#66FFFFFF"
                    android:fontFamily="sans-serif-light" />
            </LinearLayout>
        </LinearLayout>

        <!-- System lock recommendation -->
        <LinearLayout
            android:id="@+id/permSystemLock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_perm_item"
            android:padding="12dp"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="💡"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Set system lock to Swipe"
                    android:textSize="13sp"
                    android:textColor="#DDFFFFFF"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Settings → Security → Screen lock → Swipe. This lets Picture Password be your primary lock."
                    android:textSize="11sp"
                    android:textColor="#66FFFFFF"
                    android:fontFamily="sans-serif-light" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"
        android:layout_marginBottom="16dp" />

    <!-- Danger action: Clear Password -->
    <Button
        android:id="@+id/clearButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Clear Password"
        android:textSize="14sp"
        android:textColor="#AAFF6B6B"
        android:textAllCaps="false"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.01"
        android:background="@drawable/bg_button_danger"
        android:stateListAnimator="@null"
        android:enabled="false"
        android:alpha="0.4"
        android:layout_marginBottom="24dp" />

</LinearLayout>
</ScrollView>
