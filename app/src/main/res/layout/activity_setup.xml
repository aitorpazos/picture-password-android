<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/setupImageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_setup_empty"
        android:contentDescription="Setup background image" />

    <com.aitorpazos.picturepassword.ui.views.NumberGridView
        android:id="@+id/setupGridView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="top"
        android:padding="16dp"
        android:background="#CC000000">

        <TextView
            android:id="@+id/setupInstructionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 1: Choose a picture for your lock screen"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:fontFamily="sans-serif-light"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/setupActionButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose Picture" />
    </LinearLayout>

    <!-- Number selection buttons (built programmatically for high contrast) -->
    <LinearLayout
        android:id="@+id/numberButtonsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#DD000000"
        android:visibility="gone" />

</FrameLayout>
