<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/setupImageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="@android:color/darker_gray"
        android:contentDescription="Setup background image" />

    <com.aitorpazos.picturepassword.ui.views.NumberGridView
        android:id="@+id/setupGridView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="top"
        android:padding="16dp"
        android:background="#CC000000">

        <TextView
            android:id="@+id/setupInstructionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 1: Choose a picture"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/setupActionButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose Picture" />
    </LinearLayout>

    <!-- Number selection buttons (0-9) -->
    <LinearLayout
        android:id="@+id/numberButtonsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="#CC000000"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap your secret number:"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button android:id="@+id/numBtn0" android:layout_width="48dp" android:layout_height="48dp" android:text="0" android:layout_margin="2dp" />
            <Button android:id="@+id/numBtn1" android:layout_width="48dp" android:layout_height="48dp" android:text="1" android:layout_margin="2dp" />
            <Button android:id="@+id/numBtn2" android:layout_width="48dp" android:layout_height="48dp" android:text="2" android:layout_margin="2dp" />
            <Button android:id="@+id/numBtn3" android:layout_width="48dp" android:layout_height="48dp" android:text="3" android:layout_margin="2dp" />
            <Button android:id="@+id/numBtn4" android:layout_width="48dp" android:layout_height="48dp" android:text="4" android:layout_margin="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button android:id="@+id/numBtn5" android:layout_width="48dp" android:layout_height="48dp" android:text="5" android:layout_margin="2dp" />
            <Button android:id="@+id/numBtn6" android:layout_width="48dp" android:layout_height="48dp" android:text="6" android:layout_margin="2dp" />
            <Button android:id="@+id/numBtn7" android:layout_width="48dp" android:layout_height="48dp" android:text="7" android:layout_margin="2dp" />
            <Button android:id="@+id/numBtn8" android:layout_width="48dp" android:layout_height="48dp" android:text="8" android:layout_margin="2dp" />
            <Button android:id="@+id/numBtn9" android:layout_width="48dp" android:layout_height="48dp" android:text="9" android:layout_margin="2dp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
